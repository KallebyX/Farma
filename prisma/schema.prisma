generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  PHARMACIST
  ATTENDANT
  READONLY
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum InvitationChannel {
  EMAIL
  WHATSAPP
  LINK
}

enum DeliveryStatus {
  SENT
  FAILED
  SKIPPED
}

model Pharmacy {
  id          String   @id @default(uuid())
  cnpj        String   @unique
  razaoSocial String
  fantasia    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     Membership[]
  invitations Invitation[]
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String
  passwordHash   String?
  emailVerified  DateTime?
  consentVersion String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships  Membership[]
  invitedBy    Invitation[] @relation("InvitedBy")
  acceptedBy   Invitation[] @relation("AcceptedBy")
  sessions     Session[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Membership {
  id          String       @id @default(uuid())
  userId      String
  pharmacyId  String
  role        Role
  crf         String?
  status      MemberStatus @default(ACTIVE)
  invitedById String?
  joinedAt    DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@unique([userId, pharmacyId])
  @@index([pharmacyId, status])
}

model Invitation {
  id           String              @id @default(uuid())
  pharmacyId   String
  email        String
  phone        String?
  role         Role
  crf          String?
  tokenHash    String              @unique
  status       InvitationStatus    @default(PENDING)
  channels     InvitationChannel[]
  invitedById  String
  acceptedById String?
  expiresAt    DateTime
  createdAt    DateTime            @default(now())
  acceptedAt   DateTime?
  revokedAt    DateTime?

  pharmacy   Pharmacy             @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  invitedBy  User                 @relation("InvitedBy", fields: [invitedById], references: [id])
  acceptedBy User?                @relation("AcceptedBy", fields: [acceptedById], references: [id])
  deliveries InvitationDelivery[]

  @@index([pharmacyId, status])
  @@index([email])
}

model InvitationDelivery {
  id           String            @id @default(uuid())
  invitationId String
  channel      InvitationChannel
  status       DeliveryStatus
  providerId   String?
  error        String?
  attemptedAt  DateTime          @default(now())

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId])
}
